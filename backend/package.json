{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --ext ts,json --exec ts-node src/index.ts",
    "postinstall": "prisma generate",
    "prebuild": "prisma generate",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "generate:prisma": "prisma generate",
    "migrate:client-documents": "ts-node src/scripts/migrate-client-documents.ts",
    "test": "node ./node_modules/vitest/vitest.mjs run tests/app-security.test.ts tests/security-config.test.ts tests/database-url.test.ts --environment node --pool threads",
    "test:watch": "node ./node_modules/vitest/vitest.mjs tests/app-security.test.ts tests/security-config.test.ts tests/database-url.test.ts --environment node --pool threads"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "ts-node": {
    "files": true
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.1.0",
    "formidable": "^3.5.4",
    "groq-sdk": "^0.37.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/formidable": "^3.5.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.1.0",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^7.2.0",
    "nodemon": "^3.1.11",
    "prisma": "^7.3.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1",
    "xlsx": "^0.18.5"
  }
}
